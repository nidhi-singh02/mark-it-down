{
  "name": "web-to-markdown",
  "version": "0.1.1",
  "description": "Convert any web page to clean Markdown. Built for developers and LLM pipelines.",
  "author": "Nidhi Singh",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nidhi-singh02/mark-it-down.git"
  },
  "homepage": "https://github.com/nidhi-singh02/mark-it-down#readme",
  "bugs": {
    "url": "https://github.com/nidhi-singh02/mark-it-down/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "web-to-markdown": "./dist/bin/web-to-markdown.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ tests/ bin/",
    "format": "prettier --write src/ tests/ bin/",
    "format:check": "prettier --check src/ tests/ bin/",
    "validate": "npm run lint && npm run format:check && npm run typecheck && npm run test",
    "prepublishOnly": "npm run validate && npm run build"
  },
  "keywords": [
    "markdown",
    "html",
    "converter",
    "web",
    "cli",
    "llm",
    "readability"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@joplin/turndown-plugin-gfm": "^1.0.64",
    "@mozilla/readability": "^0.6.0",
    "commander": "^14.0.0",
    "linkedom": "^0.18.0",
    "turndown": "^7.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "@types/turndown": "^5.0.5",
    "eslint": "^10.0.2",
    "js-tiktoken": "^1.0.21",
    "prettier": "^3.8.1",
    "tsup": "^8.5.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "playwright": "^1.58.2"
  },
  "peerDependenciesMeta": {
    "playwright": {
      "optional": true
    }
  }
}
