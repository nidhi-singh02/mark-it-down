{
  "name": "web-to-markdown-extension",
  "version": "0.1.0",
  "private": true,
  "description": "Chrome extension to convert any web page to clean Markdown.",
  "type": "module",
  "scripts": {
    "build": "tsup && node scripts/copy-static.js",
    "dev": "tsup --watch",
    "zip": "npm run build && cd dist && zip -r ../web-to-markdown.zip ."
  },
  "dependencies": {
    "@joplin/turndown-plugin-gfm": "^1.0.64",
    "@mozilla/readability": "^0.6.0",
    "turndown": "^7.2.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.300",
    "@types/turndown": "^5.0.5",
    "tsup": "^8.5.0",
    "typescript": "^5.7.0"
  }
}
